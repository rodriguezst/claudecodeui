# Start with .gitignore patterns
/.git/
/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build outputs - EXCLUDE dist/ from ignore to include it in npm package
# dist/  <-- commented out so dist/ is included in npm package
dist-ssr/
build/
out/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Development files that shouldn't be in npm package
src/
*.log
logs/
pids
*.pid
*.seed
*.pid.lock
coverage/
*.lcov
.nyc_output
jspm_packages/
.npm
.eslintcache
.node_repl_history
*.tgz
.yarn-integrity
.env.test
.cache
.parcel-cache
.next
.nuxt
.out
.storybook-out
tmp/
temp/
.tmp/
.vite/
.netlify
.claude/
*.db
*.sqlite
*.sqlite3

# Include necessary files for npm package
# The dist/ folder will be included since it's not in this ignore list