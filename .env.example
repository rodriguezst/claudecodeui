# Claude Code UI Environment Configuration
# Only includes variables that are actually used in the code

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Disable user creation/login/auth (true/false)
CLAUDECODEUI_DISABLE_AUTH=false

# Backend server port (Express API + WebSocket server)
# Backend API and UI server port
#CLAUDECODEUI_PORT=3008

# Secret for JWT authentication (used to sign and verify JWT tokens). Change for production!
#CLAUDECODEUI_JWT_SECRET="change-this-in-production"

# (Optional) API key to protect backend API endpoints
#CLAUDECODEUI_API_KEY="supersecureapikey"

# OpenAI API key used for Whisper audio transcription features
#CLAUDECODEUI_OPENAI_API_KEY="sk-..."
